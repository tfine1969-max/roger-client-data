               jur.includes('off')||(inv.currency&&inv.currency!=='ZAR'&&inv.currency!=='R');
      });
      if(cisInvs.length>0){
        cisInvs.forEach(inv=>{
          table([
            ['Provider',inv.provider||'—'],['Product',inv.product_type||'—'],
