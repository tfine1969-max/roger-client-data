    const mandateSections = [
      ['Background', `This Investment Mandate authorises The FSP to make investment decisions on behalf of ${clientName} within strictly defined and managed parameters. This Mandate is required under The FSP's Category II FSP registration with the FSCA.`],
      ['Authorisation', 'The FSP is authorised to render discretionary intermediary services and shall exercise its discretion in managing investments on behalf of the Investor. This includes but is not limited to listed and unlisted securities, unit trusts, collective investment schemes, bonds, derivatives, and other instruments.'],
      ['Investment Objectives', `Risk Level: ${riskProfile}\nObjectives: ${advisoryNeeds.length > 0 ? advisoryNeeds.join(', ') : '—'}`],
      ['Reporting', 'The FSP shall provide the Investor with relevant portfolio information on a regular basis, with a minimum of quarterly updates.'],
      ['Termination', 'Either party may terminate this Mandate on 60 calendar days\' written notice.'],
      ['Legislation', 'This Mandate is subject to FICA (Act 38 of 2001), POCA (2001), and the Policyholder Protection Rules. The Investor confirms all investment funds are legitimate as defined under FICA and POCA.'],
      ['Confidentiality', 'The FSP will not disclose Confidential Information to any third party without prior written authority from the Investor, unless compelled by law.'],
    ];

    mandateSections.forEach(([heading, text]) => {
      pb(20);
      h3(heading);
      spacer(2);
      body(text);
      spacer(4);
    });

    spacer(6);
    h3('Annexure A — Investment Parameters');
    spacer(2);
    table([
      ['Risk Tolerance', riskProfile],
      ['Investment Objectives', advisoryNeeds.length > 0 ? advisoryNeeds.join(', ') : '—'],
    ]);

    spacer(10);
    h3('Signatures');
    spacer(6);

    body('Signature of Investor:');
    spacer(4);
    signLine(`${clientName}  ·  Date: _______________`, 100);

    spacer(4);
    body('For and on behalf of The FSP (Wealthworks Investments (Pty) Ltd):');
    spacer(4);

    if (proposal.advisor_signature_type==='draw' && proposal.advisor_signature_data) {
      pb(25); doc.addImage(proposal.advisor_signature_data,'PNG',M,y,60,18); y+=22;
    } else if (proposal.advisor_signature_type==='type' && proposal.advisor_signature_data) {
      pb(20); doc.setFont('times','italic'); doc.setFontSize(16); doc.setTextColor(...navy);
      doc.text(proposal.advisor_signature_data, M, y+6); y+=14;
    }

    signLine(`${advisorName}  ·  Date: ${signDate}`, 100);

    addFooter(pageNum);
  }

  // ══════════════════════════════════════════════════════════════════════════
  // COMPLIANCE APPENDIX
  // ══════════════════════════════════════════════════════════════════════════
  doc.addPage(); pageNum += 1; y = 30; addLogoTopRight();

  h1('Compliance & Disclosure Appendix');
  thinRule();
  spacer(2);
  doc.setFont('helvetica','normal'); doc.setFontSize(7.5); doc.setTextColor(...muted);
  doc.text('This section contains regulatory disclosures required under the FAIS Act.', M, y); y += 10;

  const appendixSections = [
    ['Introduction', 'This Disclosure and Terms of Business Document supports our commitment to full disclosure of all relevant and material information, enabling you to make well-informed decisions during the course of our professional relationship.'],
    ['Our Details', 'Wealth Works (Pty) Ltd | Reg: 2006/018307/07 | FSP 28337 (Category I)\nWealthworks Investments (Pty) Ltd | Reg: 2012/215566/07 | FSP 45624 (Category II)\n\nAuthorised to advise on: Long-Term Insurance (Cat A, B, C) | Retail Pension Benefits | Pension Fund Benefits | Collective Investment Schemes'],
    ['Key Individuals', 'Trevor Fine – B Compt H DIP Tax CFP\nMalcolm Munsamy – Certificate in Financial Planning, RE5, RE1\nRoger Eskinazi – Higher Diploma Financial Markets, MBA (Cum Laude), RE5/RE1/RE3'],
    ['Business Address', '1st Floor, Dunkeld Place, 12 North Road, Dunkeld West | Tel: 011 325 2514\nCube Workspace, The Pavilion Building, Corner Dock and Portswood Road, V&A Waterfront 8001'],
    ['Compliance Officer', 'Justin Joannides – Crux Compliance Practitioners CO3485 | Tel: 011-234 4991 | justin@cruxconsulting.co.za'],
    ['Accredited Providers', 'Allan Gray | Discovery Life | Hollard | Liberty | PPS | Momentum | Sanlam | Investec | Prime | Gryphon | Julius Baer | Credo | Old Mutual | Bright Rock'],
    ['Conflicts of Interest', 'We have adopted a Conflict of Interest Management Policy. Client interests are accorded priority over our own in the event of any conflict. A copy is available on request.'],
    ['Complaints', 'Contact: Trevor Fine | trevor@wealthworks.co.za | 1st Floor, Dunkeld Place, 12 North Road, Dunkeld West, 2196\nFAIS Ombud: Kasteel Park, Orange Building 2nd Floor, 546 Jochemus Street, Erasmuskloof, Pretoria | info@faisombud.co.za | 012 762 5000'],
    ['Privacy', 'Personal information is processed for the purpose of rendering financial advice, obtaining product information, and for administration within the group. We will not disclose your information to third parties without consent, unless required by law.'],
    ['Terms of Engagement', '1. We act in your best interests at all times\n2. All material information relevant to advice is disclosed\n3. Your information is kept confidential\n4. Remuneration is disclosed in product documentation\n5. Cooling-off rights apply as specified in product terms\n6. This report does not constitute a binding offer\n7. Past performance is not indicative of future results'],
    ['Professional Indemnity', 'Wealth Works (Pty) Ltd and Wealthworks Investments (Pty) Ltd maintain professional indemnity insurance as required under the FAIS Act.'],
  ];

  appendixSections.forEach(([heading, text]) => {
    if (y + 20 > H - 20) { addFooter(pageNum); doc.addPage(); pageNum += 1; y = 30; addLogoTopRight(); }
    doc.setFont('helvetica','bold'); doc.setFontSize(8); doc.setTextColor(...navy);
    doc.text(heading, M, y); y += 5;
    doc.setFont('helvetica','normal'); doc.setFontSize(7.5); doc.setTextColor(...black);
    const lines = doc.splitTextToSize(text, CW);
    lines.forEach(l => {
      if (y + 5 > H - 20) { addFooter(pageNum); doc.addPage(); pageNum += 1; y = 30; addLogoTopRight(); }
      doc.text(l, M, y); y += 4;
    });
    y += 5;
  });

  addFooter(pageNum);

  // ══════════════════════════════════════════════════════════════════════════
  // ADVISOR DECLARATION & CLIENT ACCEPTANCE
  // ══════════════════════════════════════════════════════════════════════════
  doc.addPage(); pageNum += 1; y = 30; addLogoTopRight();

  h1('Declarations & Acceptance');
  thinRule();
  spacer(6);

  h2('Advisor Declaration', navy);
  spacer(2);
  ['The advice provided is appropriate and suitable to the client\'s needs and circumstances',
   'All disclosures required under the FAIS Act have been made',
   'This recommendation is in the client\'s best interest',
   'The information contained in this report is accurate and complete to the best of my knowledge',
  ].forEach(b => bullet(b));

  spacer(6);
  table([
    ['Advisor Name', advisorName],
    ['Date', signDate],
  ]);
  spacer(6);

  if (proposal.advisor_signature_type==='draw' && proposal.advisor_signature_data) {
    pb(25); doc.addImage(proposal.advisor_signature_data,'PNG',M,y,60,18); y+=22;
  } else if (proposal.advisor_signature_type==='type' && proposal.advisor_signature_data) {
    pb(20); doc.setFont('times','italic'); doc.setFontSize(16); doc.setTextColor(...navy);
    doc.text(proposal.advisor_signature_data, M, y+6); y+=14;
  }

  signLine(`Advisor Signature  ·  Date: ${signDate}`, 90);

  spacer(8);
  rule();
  spacer(6);

  h2('Client Acceptance', navy);
  spacer(2);
  ['I have provided complete and accurate information to my advisor',
   'The advice and all associated risks have been explained to me clearly',
   'I understand the recommended products and their implications',
   'I have had the opportunity to ask questions and received satisfactory answers',
   'I accept the recommendations as set out in this report',
  ].forEach(b => bullet(b));

  spacer(6);
  table([['Client Name', clientName]]);
  spacer(6);

  if (proposal.personal_message) {
    pb(20);
    doc.setFont('helvetica','italic'); doc.setFontSize(8.5); doc.setTextColor(...muted);
    const msgLines = doc.splitTextToSize(`"${proposal.personal_message}"`, CW);
    msgLines.forEach(l => { pb(5); doc.text(l, M, y); y += 5; });
    spacer(6);
  }

  signLine('Client Signature  ·  Date: _______________', 90);

  addFooter(pageNum);

  return doc;
}
