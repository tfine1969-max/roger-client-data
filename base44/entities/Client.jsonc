{
  "name": "Client",
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "description": "Client full name e.g. Blackbeard, Ginette"
    },
    "account_code": {
      "type": "string",
      "description": "Account code e.g. 10012899"
    },
    "identity_no": {
      "type": "string",
      "description": "Identity number / ID number"
    },
    "notes": {
      "type": "string",
      "description": "Additional notes"
    }
  },
  "required": [
    "name"
  ]
}